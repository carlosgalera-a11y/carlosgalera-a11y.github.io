    {
      "name": "Roadmap",
      "short_name": "Roadmap",
      "url": "./?view=roadmap",
      "icons": [{ "src": "icon.svg", "sizes": "any" }]
    },
    {
      "name": "Agenda",
      "short_name": "Agenda",
      "url": "./?view=agenda",
      "icons": [{ "src": "icon.svg", "sizes": "any" }]
    }
  ]
